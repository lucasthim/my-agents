#!/usr/bin/env bash
set -euo pipefail

resolve_self() {
    local source="${BASH_SOURCE[0]}"
    while [ -L "$source" ]; do
        local dir
        dir="$(cd -P "$(dirname "$source")" && pwd)"
        source="$(readlink "$source")"
        [[ "$source" != /* ]] && source="$dir/$source"
    done
    cd -P "$(dirname "$source")" && pwd
}

REPO_DIR="$(resolve_self)"
CLAUDE_DIR="${HOME}/.claude"
LINK_DIR="${HOME}/.local/bin"
LINK_PATH="${LINK_DIR}/claudesync"

usage() {
    cat <<EOF
claudesync — sync Claude Code agents/skills between this repo and ~/.claude

Usage: claudesync <command>

Commands:
  backup    Copy agents/ and skills/ from ~/.claude into the repo
  install   Copy agents/ and skills/ from the repo into ~/.claude
  link      Symlink this script into ~/.local/bin so it runs from anywhere
  unlink    Remove the symlink from ~/.local/bin
  where     Print the resolved repo path
  help      Show this message

Repo:   ${REPO_DIR}
Target: ${CLAUDE_DIR}
EOF
}

sync_dir() {
    local src="$1" dst="$2" name="$3"
    if [[ ! -d "$src" ]]; then
        echo "skip ${name}: source ${src} does not exist"
        return
    fi
    mkdir -p "$dst"
    rsync -a --delete --exclude='.DS_Store' "${src}/" "${dst}/"
    echo "synced ${name}: ${src} -> ${dst}"
}

cmd_link() {
    mkdir -p "$LINK_DIR"
    local script_path="${REPO_DIR}/claudesync"

    if [[ -L "$LINK_PATH" ]]; then
        local current
        current="$(readlink "$LINK_PATH")"
        if [[ "$current" == "$script_path" ]]; then
            echo "already linked: ${LINK_PATH} -> ${script_path}"
        else
            ln -sf "$script_path" "$LINK_PATH"
            echo "updated link: ${LINK_PATH} -> ${script_path} (was ${current})"
        fi
    elif [[ -e "$LINK_PATH" ]]; then
        echo "error: ${LINK_PATH} exists and is not a symlink — refusing to overwrite" >&2
        exit 1
    else
        ln -s "$script_path" "$LINK_PATH"
        echo "linked: ${LINK_PATH} -> ${script_path}"
    fi

    case ":${PATH}:" in
        *":${LINK_DIR}:"*)
            echo "${LINK_DIR} is on PATH — run \`claudesync\` from anywhere"
            ;;
        *)
            echo
            echo "warning: ${LINK_DIR} is not on your PATH"
            echo "add this to your shell rc (e.g. ~/.zshrc):"
            echo "  export PATH=\"\$HOME/.local/bin:\$PATH\""
            ;;
    esac
}

cmd_unlink() {
    if [[ -L "$LINK_PATH" ]]; then
        rm "$LINK_PATH"
        echo "removed: ${LINK_PATH}"
    elif [[ -e "$LINK_PATH" ]]; then
        echo "error: ${LINK_PATH} exists but is not a symlink — leaving it alone" >&2
        exit 1
    else
        echo "nothing to unlink at ${LINK_PATH}"
    fi
}

cmd="${1:-}"
case "$cmd" in
    backup)
        sync_dir "${CLAUDE_DIR}/agents" "${REPO_DIR}/agents" "agents"
        sync_dir "${CLAUDE_DIR}/skills" "${REPO_DIR}/skills" "skills"
        ;;
    install)
        sync_dir "${REPO_DIR}/agents" "${CLAUDE_DIR}/agents" "agents"
        sync_dir "${REPO_DIR}/skills" "${CLAUDE_DIR}/skills" "skills"
        ;;
    link)
        cmd_link
        ;;
    unlink)
        cmd_unlink
        ;;
    where)
        echo "$REPO_DIR"
        ;;
    -h|--help|help|"")
        usage
        ;;
    *)
        echo "unknown command: ${cmd}" >&2
        usage >&2
        exit 1
        ;;
esac
